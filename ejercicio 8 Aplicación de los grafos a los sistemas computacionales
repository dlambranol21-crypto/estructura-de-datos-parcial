import java.util.*;

public class Ejercicio8_RecomendacionAmigos {

    static Map<String, ArrayList<String>> red = new HashMap<>();

    public static void main(String[] args) {
        agregarAmistad("Ana", "Luis");
        agregarAmistad("Ana", "Carlos");
        agregarAmistad("Luis", "Marta");
        agregarAmistad("Carlos", "Sofia");
        agregarAmistad("Marta", "Pedro");

        System.out.println("Recomendaciones para Ana: " + recomendarAmigos("Ana"));
        System.out.println("Número mínimo de conexiones entre Ana y Pedro: " + rutaMasCorta("Ana", "Pedro"));
    }

    static void agregarUsuario(String nombre) {
        if (!red.containsKey(nombre)) {
            red.put(nombre, new ArrayList<>());
        }
    }

    static void agregarAmistad(String a, String b) {
        agregarUsuario(a);
        agregarUsuario(b);
        red.get(a).add(b);
        red.get(b).add(a);
    }

    static ArrayList<String> recomendarAmigos(String usuario) {
        ArrayList<String> recomendaciones = new ArrayList<>();
        ArrayList<String> amigos = red.get(usuario);

        for (String amigo : amigos) {
            for (String amigoDeAmigo : red.get(amigo)) {
                if (!amigoDeAmigo.equals(usuario)
                        && !amigos.contains(amigoDeAmigo)
                        && !recomendaciones.contains(amigoDeAmigo)) {
                    recomendaciones.add(amigoDeAmigo);
                }
            }
        }

        return recomendaciones;
    }

    static int rutaMasCorta(String inicio, String fin) {
        Queue<String> cola = new LinkedList<>();
        Map<String, Integer> distancia = new HashMap<>();
        ArrayList<String> visitados = new ArrayList<>();

        cola.add(inicio);
        distancia.put(inicio, 0);
        visitados.add(inicio);

        while (!cola.isEmpty()) {
            String actual = cola.poll();

            if (actual.equals(fin)) {
                return distancia.get(actual);
            }

            for (String vecino : red.get(actual)) {
                if (!visitados.contains(vecino)) {
                    visitados.add(vecino);
                    cola.add(vecino);
                    distancia.put(vecino, distancia.get(actual) + 1);
                }
            }
        }

        return -1;
    }
}
