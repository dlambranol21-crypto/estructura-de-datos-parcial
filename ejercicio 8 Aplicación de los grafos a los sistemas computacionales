import java.util.*;

public class SistemaAmigos {

    private HashMap<String, ArrayList<String>> usuarios;

    public SistemaAmigos() {
        usuarios = new HashMap<>();
    }

    // Agrega un usuario si no existe
    public void agregarUsuario(String nombre) {
        if (!usuarios.containsKey(nombre)) {
            usuarios.put(nombre, new ArrayList<>());
        }
    }

    // Agrega amistad entre dos usuarios
    public void agregarAmistad(String u1, String u2) {
        agregarUsuario(u1);
        agregarUsuario(u2);

        if (!usuarios.get(u1).contains(u2)) {
            usuarios.get(u1).add(u2);
        }

        if (!usuarios.get(u2).contains(u1)) {
            usuarios.get(u2).add(u1);
        }
    }

    // Recomienda amigos de amigos
    public ArrayList<String> recomendarAmigos(String usuario) {
        ArrayList<String> resultado = new ArrayList<>();

        if (!usuarios.containsKey(usuario)) {
            return resultado;
        }

        ArrayList<String> amigosDirectos = usuarios.get(usuario);

        for (String amigo : amigosDirectos) {
            ArrayList<String> amigosDeEseAmigo = usuarios.get(amigo);

            for (String posible : amigosDeEseAmigo) {
                if (!posible.equals(usuario) &&
                    !amigosDirectos.contains(posible) &&
                    !resultado.contains(posible)) {
                    resultado.add(posible);
                }
            }
        }

        return resultado;
    }

    // Calcula la ruta más corta entre dos usuarios
    public int rutaMasCorta(String u1, String u2) {
        if (!usuarios.containsKey(u1) || !usuarios.containsKey(u2)) {
            return -1;
        }

        Queue<String> cola = new LinkedList<>();
        HashMap<String, Integer> niveles = new HashMap<>();

        cola.add(u1);
        niveles.put(u1, 0);

        while (!cola.isEmpty()) {
            String actual = cola.poll();
            int distanciaActual = niveles.get(actual);

            if (actual.equals(u2)) {
                return distanciaActual;
            }

            for (String vecino : usuarios.get(actual)) {
                if (!niveles.containsKey(vecino)) {
                    cola.add(vecino);
                    niveles.put(vecino, distanciaActual + 1);
                }
            }
        }

        return -1;
    }

    // Muestra la red social
    public void mostrar() {
        for (String usuario : usuarios.keySet()) {
            System.out.println(usuario + ": " + usuarios.get(usuario));
        }
    }

    public static void main(String[] args) {
        SistemaAmigos red = new SistemaAmigos();

        red.agregarAmistad("Juan", "Pedro");
        red.agregarAmistad("Juan", "Laura");
        red.agregarAmistad("Pedro", "Sofia");
        red.agregarAmistad("Laura", "Carlos");
        red.agregarAmistad("Carlos", "Elena");
        red.agregarAmistad("Sofia", "Mario");

        System.out.println("Lista de usuarios y amistades:");
        red.mostrar();

        System.out.println("\nRecomendaciones para Juan:");
        System.out.println(red.recomendarAmigos("Juan"));

        System.out.println("\nRuta más corta entre Juan y Elena:");
        System.out.println(red.rutaMasCorta("Juan", "Elena"));

        System.out.println("\nRuta más corta entre Juan y Mario:");
        System.out.println(red.rutaMasCorta("Juan", "Mario"));
    }
}
